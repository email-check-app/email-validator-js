{
  "name": "@emailcheck/email-validator-js",
  "version": "3.4.3",
  "private": false,
  "description": "Advanced email validation with MX records, SMTP verification, disposable email detection, batch processing, and caching. Production-ready with TypeScript support.",
  "keywords": [
    "email-validation",
    "email-verification",
    "email-validator",
    "email-checker",
    "smtp-verification",
    "mx-records",
    "disposable-emails",
    "free-emails",
    "batch-validation",
    "email-typos",
    "email-regex",
    "typescript",
    "cache",
    "rfc5321"
  ],
  "homepage": "https://github.com/email-check-app/email-validator-js#readme",
  "bugs": "https://github.com/email-check-app/email-validator-js/issues",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/email-check-app/email-validator-js.git"
  },
  "license": "BSL 1.1",
  "author": "EMAIL-CHECK.APP <support@email-check.app> (https://email-check.app)",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.esm.js",
      "types": "./dist/index.d.ts"
    },
    "./serverless": {
      "require": "./dist/serverless/index.cjs.js",
      "import": "./dist/serverless/index.esm.js",
      "types": "./dist/serverless/index.d.ts"
    },
    "./serverless/verifier": {
      "require": "./dist/serverless/verifier.cjs.js",
      "import": "./dist/serverless/verifier.esm.js",
      "types": "./dist/serverless/verifier.d.ts"
    },
    "./serverless/aws": {
      "require": "./dist/serverless/adapters/aws-lambda.cjs.js",
      "import": "./dist/serverless/adapters/aws-lambda.esm.js",
      "types": "./dist/serverless/adapters/aws-lambda.d.ts"
    },
    "./serverless/vercel": {
      "require": "./dist/serverless/adapters/vercel.cjs.js",
      "import": "./dist/serverless/adapters/vercel.esm.js",
      "types": "./dist/serverless/adapters/vercel.d.ts"
    },
    "./serverless/cloudflare": {
      "require": "./dist/serverless/adapters/cloudflare.cjs.js",
      "import": "./dist/serverless/adapters/cloudflare.esm.js",
      "types": "./dist/serverless/adapters/cloudflare.d.ts"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.cjs && rollup -c rollup.config.serverless.cjs && cp src/*.json dist/",
    "build:main": "rollup -c rollup.config.cjs",
    "build:serverless": "rollup -c rollup.config.serverless.cjs",
    "check": "biome check --write",
    "format": "biome format --write",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "husky",
    "prepublishOnly": "bun run build",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "test": "bun run test:core && bun run test:adapters",
    "test:unit": "bun run test",
    "test:core": "bun test __tests__/0005-batch-verification.test.ts __tests__/0006-detailed-verification.test.ts __tests__/0008-utils.test.ts __tests__/0107-socket-mock.test.ts __tests__/0110-smtp-verifier.unit.test.ts __tests__/0111-smtp-dsn.test.ts __tests__/0200-cache.test.ts __tests__/0203-redis-adapter.test.ts __tests__/0204-redis-scan-clear.test.ts __tests__/0205-lru-adapter.test.ts __tests__/0300-domain-suggester.test.ts __tests__/0301-parse-domain-whois-data.test.ts __tests__/0303-whois-unit.test.ts __tests__/0304-integrated-domain-suggestion.test.ts __tests__/0305-integrated-name-detection-legacy.test.ts __tests__/0306-whois-parser-tld-dispatch.test.ts __tests__/0402-name-detector.test.ts __tests__/0403-integrated-name-detection.test.ts __tests__/0500-serverless-core.test.ts __tests__/0503-is-spam-name.test.ts __tests__/0510-shared-validation.test.ts __tests__/0511-shared-cors.test.ts __tests__/0530-edge-cache.test.ts __tests__/0600-spam-detection.test.ts --concurrency=1",
    "test:adapters": "bun test __tests__/0501-serverless-aws-lambda.test.ts __tests__/0502-serverless-vercel.test.ts __tests__/0512-shared-dispatch.test.ts --concurrency=1",
    "test:extras": "bun test extras/check-if-email-exists/__tests__ --concurrency=1",
    "test:integration": "INTEGRATION=1 bun test __tests__/integration --concurrency=1",
    "test:all": "bun run test && bun run test:integration",
    "test-ci": "bun run test",
    "typecheck": "tsc --pretty --skipLibCheck --noEmit && tsc --project tsconfig.test.json --pretty --skipLibCheck --noEmit"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.{json,md,yml,yaml}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "psl": "^1.15.0",
    "string-similarity-js": "^2.1.4",
    "tiny-lru": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/bun": "^1.3.13",
    "@types/node": "25.6.0",
    "esbuild": "^0.28.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "rollup": "^4.60.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "tslib": "^2.8.1",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">= 18.0",
    "bun": ">= 1.3"
  }
}
